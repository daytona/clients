{
  "extends": "../tsconfig.base.json",
  "files": [],
  "include": ["src/**/*.ts"],
  "exclude": ["jest.config.ts", "src/**/*.spec.ts", "src/**/*.test.ts"],
  "compilerOptions": {
    "esModuleInterop": true,
    "lib": ["es2024", "dom"],
    "types": ["node"],
    "declaration": true,
    "declarationMap": true,
    "resolveJsonModule": true,
    "experimentalDecorators": false,
    "emitDecoratorMetadata": false
  }
}
